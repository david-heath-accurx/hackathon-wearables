    {
      "name": "6 — Admin Query (Service Key)",
      "description": "These requests authenticate using a JWT signed with the service signing key from Azure Key Vault. The pre-request script generates the token automatically from the serviceSigningKey collection variable.",
      "item": [
        {
          "name": "6.0 Re-register Device (Setup)",
          "description": "Folder 5 wiped all registrations. Re-register before running admin queries.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Device re-registered', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/device-registrations",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientIdentifier\": \"{{patientIdentifier}}\",\n  \"dateOfBirth\": \"{{dateOfBirth}}\",\n  \"practiceOdsCode\": \"{{practiceOdsCode}}\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
            }
          }
        },
        {
          "name": "6.1 Get Patient Data by Identifier + DOB",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Build a HS256 JWT signed with the Key Vault service signing key",
                  "const header = btoa(JSON.stringify({ alg: 'HS256', typ: 'JWT' }))",
                  "    .replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');",
                  "",
                  "const now = Math.floor(Date.now() / 1000);",
                  "const payload = btoa(JSON.stringify({",
                  "    iss: 'hackathon-wearables-service',",
                  "    aud: 'hackathon-wearables-admin',",
                  "    sub: 'service',",
                  "    iat: now,",
                  "    exp: now + 3600",
                  "})).replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');",
                  "",
                  "const signingInput = header + '.' + payload;",
                  "const keyBase64 = pm.collectionVariables.get('serviceSigningKey');",
                  "const keyBytes = CryptoJS.enc.Base64.parse(keyBase64);",
                  "const sig = CryptoJS.HmacSHA256(signingInput, keyBytes);",
                  "const sigB64 = CryptoJS.enc.Base64.stringify(sig)",
                  "    .replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');",
                  "",
                  "pm.collectionVariables.set('serviceToken', signingInput + '.' + sigB64);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Request succeeded', () => pm.response.to.have.status(200));",
